{
  "name": "@cc-wf-studio/core",
  "version": "0.1.0",
  "description": "Core workflow schema, parser, serializer, Mermaid generation, and Claude Code export logic for cc-wf-studio",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/types/mcp-node.d.ts",
      "default": "./dist/types/mcp-node.js"
    },
    "./resources/workflow-schema.json": "./resources/workflow-schema.json",
    "./resources/workflow-schema.toon": "./resources/workflow-schema.toon",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "resources",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/breaking-brake/cc-wf-studio",
    "directory": "packages/core"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm run generate:toon && tsc",
    "check": "tsc --noEmit",
    "generate:toon": "tsx scripts/generate-toon-schema.ts",
    "lint": "echo 'core: no lint config yet'",
    "format": "echo 'core: no format config yet'",
    "test": "echo 'core: no tests yet'"
  },
  "devDependencies": {
    "@toon-format/toon": "^2.1.0",
    "@types/node": "^25.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.3.0"
  }
}
