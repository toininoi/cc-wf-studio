{
  "name": "@cc-wf-studio/cli",
  "version": "0.0.0",
  "description": "Command-line tool for cc-wf-studio: render, validate, and run workflows, plus a stdio MCP server entry.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ccwf": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/breaking-brake/cc-wf-studio",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "check": "tsc --noEmit",
    "lint": "echo 'cli: no lint config yet'",
    "format": "echo 'cli: no format config yet'",
    "test": "echo 'cli: no tests yet'"
  },
  "dependencies": {
    "@cc-wf-studio/core": "workspace:*",
    "@cc-wf-studio/mcp": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.3.0"
  }
}
